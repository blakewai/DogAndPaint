<Page x:Class="DogAndPaint.Pages.MainPages.MainPanel"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DogAndPaint.Pages.MainPages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MainPanel">

    <Grid>
        <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Center">
            <Button Name="MainPanelBT" Click="MainPanelBT_Click" Cursor="Hand" Background="{x:Null}" BorderThickness="0">
                <StackPanel Orientation="Horizontal">
                    <Image Name="LogoImage" 
                           Source="/Image/DogAndPaint.png" 
                           Height="40"/>
                    <TextBlock Name="LogoTextBlock" 
                               Text="СОБАКА-И ТОЧКА"
                               FontSize="15"
                               FontWeight="ExtraBold"
                               Foreground="#205E45"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

        </StackPanel>
    </Grid>
</Page>
